# ─── Multi-Agent Collaboration — Environment Variables ───────────────────────
# Copy this file to .env and fill in the keys for the providers you want to use.
# The app will auto-enable any provider whose key is present.
# Restart the Node server after editing.

# Anthropic — https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI — https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Grok (xAI) — https://console.x.ai
GROK_API_KEY=xai-...

# Google Gemini — https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIza...

# Perplexity — https://www.perplexity.ai/settings/api
PERPLEXITY_API_KEY=pplx-...

# ─── Server ───────────────────────────────────────────────────────────────────
# Port the Node process listens on (Nginx proxies /api/* to this port).
PORT=3001
